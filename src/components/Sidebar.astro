---
import type { Props } from "@astrojs/starlight/props";
import Default from "@astrojs/starlight/components/Sidebar.astro";

const { sidebar } = Astro.props;

// If sidebar is undefined or empty, it might be that we're on a page where it's not passed
// or Starlight's sidebar logic is different in dev vs build.
// Let's try to see if we can get the full sidebar from somewhere else if needed,
// but usually it should be in Props.
---

{sidebar && sidebar.length > 0 ? (
  <starlight-sidebar-tabs class="sidebar-tabs-container">
    <div class="sidebar-tabs-header">
      {sidebar.map((group, index) => (
        <button
          class="sidebar-tab-button"
          data-index={index}
          aria-selected={index === 0}
          type="button"
        >
          {(group as any).label || 'Other'}
        </button>
      ))}
    </div>
    <div class="sidebar-tabs-content">
      {sidebar.map((group, index) => (
        <div
          class="sidebar-tab-panel"
          data-index={index}
          hidden={index !== 0}
        >
          <Default {...Astro.props} sidebar={(group as any).items || (group.type === 'link' ? [group] : [])} />
        </div>
      ))}
    </div>
  </starlight-sidebar-tabs>
) : (
  <Default {...Astro.props} />
)}

<script>
  class StarlightSidebarTabs extends HTMLElement {
    constructor() {
      super();
      const buttons = this.querySelectorAll<HTMLButtonElement>('.sidebar-tab-button');
      const panels = this.querySelectorAll<HTMLElement>('.sidebar-tab-panel');

      const savedIndex = sessionStorage.getItem('starlight-sidebar-active-tab');
      if (savedIndex !== null) {
        this.setActiveTab(parseInt(savedIndex, 10), buttons, panels);
      }

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const index = parseInt(button.dataset.index || '0', 10);
          this.setActiveTab(index, buttons, panels);
          sessionStorage.setItem('starlight-sidebar-active-tab', index.toString());
        });
      });
    }

    setActiveTab(index: number, buttons: NodeListOf<HTMLButtonElement>, panels: NodeListOf<HTMLElement>) {
      buttons.forEach((b, i) => {
        const isSelected = i === index;
        b.setAttribute('aria-selected', isSelected.toString());
      });
      panels.forEach((p, i) => {
        const isSelected = i === index;
        p.hidden = !isSelected;
      });
    }
  }

  if (!customElements.get('starlight-sidebar-tabs')) {
    customElements.define('starlight-sidebar-tabs', StarlightSidebarTabs);
  }
</script>

<style is:global>
  starlight-sidebar-tabs {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .sidebar-tabs-header {
    display: flex;
    gap: 0.25rem;
    padding: 0.5rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    overflow-x: auto;
    scrollbar-width: none;
    background-color: var(--sl-color-bg-sidebar);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .sidebar-tabs-header::-webkit-scrollbar {
    display: none;
  }
  .sidebar-tab-button {
    background: none;
    border: none;
    padding: 0.4rem 0.8rem;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    white-space: nowrap;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    border-radius: 0.25rem;
    transition: all 0.2s ease;
  }
  .sidebar-tab-button[aria-selected="true"] {
    background-color: var(--sl-color-accent-low);
    color: var(--sl-color-white);
  }
  .sidebar-tab-button:hover:not([aria-selected="true"]) {
    color: var(--sl-color-white);
    background-color: var(--sl-color-gray-6);
  }
  .sidebar-tabs-content {
    flex: 1;
    overflow-y: auto;
  }
</style>
